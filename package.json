{
  "name": "easydraft",
  "version": "1.0.0",
  "description": "Draft Management System for OBS overlays with Electron",
  "main": "dist/main/index.js",
  "homepage": "./",
  "scripts": {
  "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.main.json && electron .\"",
  "build": "tsc -p tsconfig.main.json && vite build",
  "start": "npm run build && electron .",
  "pack": "electron-builder --dir",
  "dist": "electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "express": "^4.18.2",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.16.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.easydraft.app",
    "productName": "EasyDraft",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "public/**/*"
    ],
    "directories": {
      "buildResources": "public"
    }
  }
}
